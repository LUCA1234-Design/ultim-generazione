# V17 Agentic AI Trading System — Environment Variables Template
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the .env file — it is listed in .gitignore.

# ============================================================
# Binance API credentials (Futures)
# Generate at: https://www.binance.com/en/my/settings/api-management
# ============================================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ============================================================
# Telegram Bot
# Create a bot via @BotFather and get your chat ID via @userinfobot
# ============================================================
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
